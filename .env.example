# ============================================================
# Medora AI — Environment Variables Template
# Copy this file to .env (backend) and frontend/.env.local
# ============================================================

# ----- DATABASE -----
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/medora_db
SPRING_DATASOURCE_USERNAME=medora_user
SPRING_DATASOURCE_PASSWORD=medora_pass

# ----- JWT -----
JWT_SECRET=your-super-secret-jwt-key-min-256-bits-change-this-in-production
JWT_EXPIRATION_MS=86400000

# ----- GEMINI AI -----
SPRING_AI_GOOGLE_API_KEY=your-gemini-api-key-here

# ----- REDIS (optional) -----
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ----- FRONTEND -----
NEXT_PUBLIC_API_URL=http://localhost:8080/api
